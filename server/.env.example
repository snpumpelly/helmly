# Copy this file to .env and fill in your values
# Never commit .env to git — it is in .gitignore

# Anthropic (required for AI chat)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Server
PORT=3001
CORS_ORIGIN=http://localhost:3000
REQUIRE_SUBSCRIPTION=false

# Amazon Product Advertising API (PA-API 5.0) — server-side only
# Get credentials at: https://affiliate-program.amazon.com → Tools → Product Advertising API
AMAZON_ACCESS_KEY=amzn1.application-oa2-client.xxxxxxxx
AMAZON_SECRET_KEY=amzn1.oa2-cs.v1.xxxxxxxx
AMAZON_STORE_ID=your-store-id-20
AMAZON_REGION=us-east-1
